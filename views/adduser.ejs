<!DOCTYPE html>
<html>
<head>
    <title>Add User</title>
</head>
<body>

    <h1>Add User</h1>

    <form action="/submituser" method="post">

        <input
            type="text"
            name="username"
            placeholder="Enter Username"
            required
        >
        <br><br>

        <input
            type="email"
            name="email"
            placeholder="Enter Email"
            required
        >
        <br><br>

        <input
            type="password"
            name="password"
            placeholder="Enter Password"
            required
        >
        <br><br>

        <button type="submit">
            Submit
        </button>

    </form>

</body>
</html>